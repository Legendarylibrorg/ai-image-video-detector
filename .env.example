# Copy this file to `.env` and update values as needed.
# Example: cp .env.example .env

# Add a real token before `./local.sh smoke` or `./local.sh run`.
HF_TOKEN=''

# Keep the collector on the built-in Hugging Face-only path.
BEST_DS_NO_DEFAULT_SOURCES=1
FAST_NO_DEFAULT_SOURCES=1

# Collection, cache, and rate-limit tuning defaults now live in the scripts.
# Only add overrides here if you intentionally want behavior different from the repo defaults.

# Keep scanning enabled.
MALWARE_SCAN=1

# Keep a simple disk-space guard.
DOCTOR_MIN_FREE_GB=40
