# Copy this file to `.env` and update values as needed.
# Example: cp .env.example .env

# Optional until you want collection or training.
# Add a real token before `./local.sh collect`, `./local.sh train`, or `./local.sh setup-full`.
HF_TOKEN=''

# Keep collection HF-only.
BEST_DS_HF_ONLY=1
BEST_DS_NO_DEFAULT_SOURCES=1
FAST_HF_ONLY=1
FAST_NO_DEFAULT_SOURCES=1

# Diversity safety gates.
BEST_DS_MIN_HF_SOURCES_WITH_ACCEPTED=28
BEST_DS_MIN_HF_SOURCES_PER_CLASS=16
BEST_DS_MIN_HF_SOURCES_PER_SPLIT_CLASS=10
BEST_DS_MAX_PER_SOURCE_CLASS=12000
BEST_DS_MAX_PER_SOURCE_SPLIT_CLASS=4000
BEST_DS_HARDNEG_FRACTION=0.35
FAST_MIN_HF_SOURCES_WITH_ACCEPTED=16
FAST_MIN_HF_SOURCES_PER_CLASS=10
FAST_MIN_HF_SOURCES_PER_SPLIT_CLASS=6
FAST_MAX_PER_SOURCE_CLASS=3000
FAST_MAX_PER_SOURCE_SPLIT_CLASS=1000
FAST_HARDNEG_FRACTION=0.25
DIVERSE_MIN_HF_SOURCES_WITH_ACCEPTED=24
DIVERSE_MIN_HF_SOURCES_PER_CLASS=14
DIVERSE_MIN_HF_SOURCES_PER_SPLIT_CLASS=8
DIVERSE_MAX_PER_SOURCE_CLASS=16000
DIVERSE_MAX_PER_SOURCE_SPLIT_CLASS=5500
DIVERSE_HARDNEG_FRACTION=0.5
DIVERSE_MAX_SOURCE_SHARE_PER_SPLIT=0.22
DIVERSE_MAX_SOURCE_SHARE_PER_SPLIT_CLASS=0.3

# Hugging Face quality filters.
BEST_DS_HF_MIN_DOWNLOADS=80
BEST_DS_HF_MIN_LIKES=2
BEST_DS_HF_MIN_QUALITY_SCORE=1.7
DIVERSE_HF_MIN_DOWNLOADS=100
DIVERSE_HF_MIN_LIKES=2
DIVERSE_HF_MIN_QUALITY_SCORE=1.85

# 5-minute rate-limit friendly defaults.
BEST_DS_HF_CACHE_FILE=./.local/hf_discovered_sources.txt
DIVERSE_HF_CACHE_FILE=./.local/hf_diverse_sources.txt
BEST_DS_CACHE_DIR=./.local/hf
DIVERSE_CACHE_DIR=./.local/hf
DIVERSE_REPO_BASE_PAUSE_MS=1400
DIVERSE_REPO_JITTER_MS=1200
DIVERSE_REPO_COOLDOWN_MS=45000
VIDEO_MODE=snapshot
VIDEO_SNAPSHOT_MAX_WORKERS=1

# Keep scanning enabled.
MALWARE_SCAN=1

# Setup/doctor defaults.
SETUP_MAX_ATTEMPTS=4
SETUP_RETRY_SLEEP_SEC=45
DOCTOR_MIN_FREE_GB=40
