# Copy this file to `.env` and update values as needed.
# Example: cp .env.example .env

# Add a Hugging Face read token before `./local.sh smoke` or `./local.sh run`.
HF_TOKEN=''

# Keep the collector on the built-in Hugging Face-only path.
BEST_DS_NO_DEFAULT_SOURCES=1

# Collection, cache, and rate-limit tuning defaults now live in the scripts.
# Only add overrides here if you intentionally want behavior different from the repo defaults.
# Hugging Face cache is reused from ./.local/hf by both native runs and Docker Compose.

# Hugging Face Hub datasets that need custom loading scripts: enable trust, list allowed repos, acknowledge risk.
# AID_HF_TRUST_REMOTE_CODE=1
# AID_HF_TRUST_REMOTE_ALLOWLIST=MyOrg/trusted-dataset,OtherOrg/other-set
# AID_ACCEPT_HF_TRUST_REMOTE_RISK=1
# Legacy only (trust for every dataset): add this line too (dangerous):
# AID_HF_TRUST_REMOTE_UNSAFE_GLOBAL=1

# Collection paths must resolve under this directory (defaults to process cwd). Compose sets /workspace.
# AID_WORKSPACE_ROOT=/workspace

# Checkpoint loads: staged copy via O_NOFOLLOW before parse (default on). Set to 0 only on trusted paths.
# AID_CHECKPOINT_LOAD_STAGING=0

# Skip dataset symlink preflight (tests / special cases only; not recommended for real training).
# AID_SKIP_DATA_PREFLIGHT=1

# Keep scanning enabled.
MALWARE_SCAN=1

# Keep a simple disk-space guard.
DOCTOR_MIN_FREE_GB=40
